# ========== GENERAL ==========
COMPOSE_PROJECT_NAME=soclab
TIMEZONE=UTC
DOMAIN=soc-lab.local

# ========== NETWORK ==========
SUBNET=10.100.0.0/24
GATEWAY=10.100.0.1

# ========== ELASTICSEARCH ==========
