ELASTIC_PASSWORD=CHANGE_ME
ELASTIC_CLUSTER_NAME=soc-cluster
ELASTIC_NODE_NAME=node-1
ELASTIC_MEM_LIMIT=4g
ELASTIC_HEAP_SIZE=2g

